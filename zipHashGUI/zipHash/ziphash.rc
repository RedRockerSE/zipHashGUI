#include <windows.h>

1 VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x4L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Example Company\0"
            VALUE "FileDescription", "ZipHash - File Hash Calculator\0"
            VALUE "FileVersion", "1.0.0.0\0"
            VALUE "InternalName", "zipHashGUI.exe\0"
            VALUE "OriginalFilename", "zipHashGUI.exe\0"
            VALUE "ProductName", "ZipHash\0"
            VALUE "ProductVersion", "1.0.0.0\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END

1 RT_MANIFEST "ziphash.manifest"
